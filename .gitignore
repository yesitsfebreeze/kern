# Cargo.lock IS tracked: kern ships a binary daemon, so the lockfile is
# committed for reproducible builds across machines.
/target

# kern runtime state (configless by default; kern.toml only for overrides)
/.kern/
ghpages/.kern/

# stray crate-local runtime journals from in-dir test runs (tests use tempdir;
# this never belongs in the repo)
/src/**/.kern/

# daemon runtime state — relay (intake, journal, graph, logs), mesh (LMDB +
# history journal), git-fs
/.relay/
/.mesh/
/.git-fs/

# generated bench traces — the generator is deterministic (same args produce a
# byte-identical trace), so these are regenerated rather than committed
/traces/

# LoCoMo eval corpus — CC BY-NC 4.0, user-supplied, never redistributed in-repo (#36)
/eval/

# machine project layer — per-repo, locally generated by /oil, never committed
/.machine/

# packaged landing-page artifact (ghpages/ is the source)
ghpages.zip

# splinter is a local index layer — derived from the source and regenerated by
# the watcher, so nothing under it belongs in the repo
/.splinter/

# local tooling / vaults (not part of the product). `update.sh` is the one
# exception: it is this repo declaring what a fresh checkout must install, so it
# has to ship. Ignore the contents, not the directory, or git never descends far
# enough to see the unignore.
/.pi/*
!/.pi/update.sh
/.claude
/.obsidian
/.jd/
/.cchome/
/.voit/
/.worktrees/
/.pi-subagents/
/.voitbus.json
/.voitbus.json.tmp
/.voitbus.sock
/.voitbus.pid

__pycache__/
NUL

# docs site (fumadocs) — generated artifacts only, source is tracked
/docs/site/node_modules/
/docs/site/.next/
/docs/site/out/
/docs/site/.source/
/docs/site/next-env.d.ts

# docs site: generated LLM page mirrors + build output
/docs/site/public/
/docs/site/out/
/docs/site/.next/

# live worktree ledger for the 15-minute workflow loop — per-machine runtime
# state, rewritten every firing; never committed (see the file itself)
/worktrees.md

# per-worktree pointer at the shared build cache (see worktrees.md) — machine
# local, never committed; a tracked absolute path would break every other clone
/.cargo/
