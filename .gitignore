# Cargo.lock IS tracked: kern ships a binary daemon, so the lockfile is
# committed for reproducible builds across machines.
/target

# kern runtime state (configless by default; kern.toml only for overrides)
/.kern/
ghpages/.kern/

# stray crate-local runtime journals from in-dir test runs (tests use tempdir;
# this never belongs in the repo)
/src/**/.kern/

# daemon runtime state — relay (capture, journal, graph, logs), mesh (LMDB +
# history journal), git-fs
/.relay/
/.mesh/
/.git-fs/

# generated bench traces — the generator is deterministic (same args produce a
# byte-identical trace), so these are regenerated rather than committed
/traces/

# LoCoMo eval corpus — CC BY-NC 4.0, user-supplied, never redistributed in-repo (#36)
/eval/

# machine project layer — per-repo, locally generated by /oil, never committed
/.machine/

# packaged landing-page artifact (ghpages/ is the source)
ghpages.zip

# splinter index is derived; only the durable per-file notes are committed
.splinter/**
!.splinter/**/
!.splinter/**/*.splinter.md

# local tooling / vaults (not part of the product)
/.claude
/.obsidian
/.jd/
/.cchome/
/.voit/
/.worktrees/
/.pi-subagents/
/.voitbus.json
/.voitbus.json.tmp
/.voitbus.sock
/.voitbus.pid

__pycache__/
NUL
