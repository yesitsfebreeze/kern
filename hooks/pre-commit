#!/usr/bin/env bash
# oracle ruling, rules 1-2 (per-clone install product; see ORACLE.md "Ruling")
set -u

staged=$(git diff --cached --name-only --diff-filter=ACMRD)
[ -z "$staged" ] && exit 0

# The oracle file set lives at the repo root or under docs/oracle/; accept
# either, so a docs reorganisation cannot silently disable the ruling.
if [ -f docs/oracle/CHANGELOG.md ] || git show :docs/oracle/CHANGELOG.md >/dev/null 2>&1; then
  ORACLE_DIR='docs/oracle/'
else
  ORACLE_DIR=''
fi
CHANGELOG="${ORACLE_DIR}CHANGELOG.md"

oracle_touched=$(printf '%s\n' "$staged" | grep -Ex "${ORACLE_DIR}(ORACLE|VISION|FEATURES|ROADMAP|SPECIALISTS)\.md" || true)

count_entries() { grep -c 'Decided by:' || true; }
after=$(git show ":$CHANGELOG" 2>/dev/null | count_entries)
if git rev-parse -q --verify HEAD >/dev/null 2>&1; then
  before=$(git show "HEAD:$CHANGELOG" 2>/dev/null | count_entries)
  has_parent=1
else
  before=0
  has_parent=0
fi
: "${after:=0}" "${before:=0}"

# Rule 1: oracle-governed markdown moved -> CHANGELOG.md must gain an entry,
# and each new entry must cite a pinned behavior or `the oracle`.
if [ -n "$oracle_touched" ]; then
  if [ "$after" -le "$before" ]; then
    echo "oracle: blocked. These files changed:" >&2
    printf '  %s\n' $oracle_touched >&2
    echo "but $CHANGELOG gained no new 'Decided by:' entry ($before before, $after after)." >&2
    echo "Recording is part of deciding — add the entry in this same commit." >&2
    exit 1
  fi

  if [ "$has_parent" = 1 ]; then
    new_entries=$(git diff --cached HEAD -- "$CHANGELOG" | grep '^+.*Decided by:' || true)
  else
    new_entries=$(git show ":$CHANGELOG" 2>/dev/null | grep 'Decided by:' || true)
  fi

  pinned=""
  if [ -f CLAUDE.local.md ]; then
    pinned=$(grep -oE '[A-Za-z0-9._-]+\.md' CLAUDE.local.md | grep -vx 'ORACLE.md' | sed 's/\.md$//' | sort -u || true)
  fi

  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    if printf '%s' "$entry" | grep -q 'the oracle'; then
      continue
    fi
    if [ -z "$pinned" ]; then
      echo "oracle: warning — pinned behavior list is empty; cannot check citation:" >&2
      echo "  $entry" >&2
      continue
    fi
    cited=0
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      if printf '%s' "$entry" | grep -qF "$name"; then cited=1; break; fi
    done <<< "$pinned"
    if [ "$cited" = 0 ]; then
      echo "oracle: blocked. New $CHANGELOG entry cites no pinned behavior and not 'the oracle':" >&2
      echo "  $entry" >&2
      echo "Pinned behaviors: $(printf '%s' "$pinned" | tr '\n' ' ')" >&2
      exit 1
    fi
  done <<< "$new_entries"
fi

# Rule 2: non-markdown changes without CHANGELOG.md -> warn, let through.
non_md=$(printf '%s\n' "$staged" | grep -v '\.md$' || true)
changelog_staged=$(printf '%s\n' "$staged" | grep -qx "$CHANGELOG" && echo yes || true)
if [ -n "$non_md" ] && [ -z "$changelog_staged" ]; then
  echo "oracle: warning — non-markdown files changed without $CHANGELOG; a feature or decision may have gone unrecorded." >&2
fi

exit 0
